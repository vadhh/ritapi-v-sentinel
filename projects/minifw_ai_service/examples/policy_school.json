{
  "policy_metadata": {
    "policy_id": "POL-SCHL001",
    "version": "1.0.0",
    "sector": "school",
    "status": "active",
    "created_at": "2026-01-22T07:00:00Z",
    "created_by": "admin",
    "description": "Educational institution policy with strict student protection and immediate blocking",
    "compliance_tags": ["COPPA", "FERPA", "Child_Safety"]
  },
  
  "sector_config": {
    "network_segments": {
      "student_labs": {
        "subnets": ["10.10.0.0/16"],
        "block_threshold": 25,
        "monitor_threshold": 10,
        "description": "Computer labs for students - strictest controls"
      },
      "student_wifi": {
        "subnets": ["10.11.0.0/16"],
        "block_threshold": 30,
        "monitor_threshold": 15,
        "description": "Student WiFi access - very strict"
      },
      "teacher_network": {
        "subnets": ["10.20.0.0/16"],
        "block_threshold": 50,
        "monitor_threshold": 30,
        "description": "Teacher workstations and devices"
      },
      "admin_network": {
        "subnets": ["10.30.0.0/16"],
        "block_threshold": 70,
        "monitor_threshold": 50,
        "description": "Administrative systems (SIS, HR, Finance)"
      }
    },
    "operating_hours": {
      "business_hours": {
        "start": "07:00",
        "end": "16:00"
      },
      "timezone": "Asia/Jakarta",
      "after_hours_strictness": "strict",
      "note": "Even stricter after school hours"
    },
    "risk_tolerance": "very_low",
    "critical_systems": [
      "10.30.1.1",
      "sis.school.local",
      "lms.school.local",
      "attendance.school.local"
    ]
  },
  
  "ai_detection": {
    "feature_weights": {
      "dns_weight": 40,
      "sni_weight": 35,
      "asn_weight": 15,
      "burst_weight": 5,
      "behavioral_weight": 5
    },
    "threat_categories": {
      "gambling": {
        "enabled": true,
        "base_score": 90,
        "action": "block",
        "feed_sources": ["kominfo", "curated_gambling_list", "student_protection_list"]
      },
      "malware": {
        "enabled": true,
        "base_score": 95,
        "action": "block"
      },
      "api_abuse": {
        "enabled": true,
        "detection_threshold": 50,
        "action": "block"
      },
      "social_media": {
        "enabled": true,
        "action": "block",
        "allowed_hours": [],
        "note": "Social media completely blocked during school hours"
      }
    },
    "burst_detection": {
      "dns_queries_per_minute_monitor": 60,
      "dns_queries_per_minute_block": 100,
      "connection_rate_limit": 150
    }
  },
  
  "enforcement_rules": [
    {
      "rule_id": "RULE-S001",
      "priority": 1,
      "name": "Student Network Zero Tolerance",
      "description": "IMMEDIATE BLOCK - Any detection on student networks blocked instantly",
      "enabled": true,
      "conditions": {
        "ai_score_min": 25,
        "source_segments": ["student_labs", "student_wifi"],
        "threat_categories": ["gambling", "malware", "api_abuse"]
      },
      "action": {
        "type": "block",
        "duration_seconds": 604800,
        "alert_channels": ["email", "syslog", "dashboard"],
        "note": "7-day block, no warnings for student networks"
      },
      "metadata": {
        "created_by": "principal",
        "created_at": "2026-01-22T07:00:00Z",
        "tags": ["critical", "students", "zero_tolerance", "child_protection"]
      }
    },
    {
      "rule_id": "RULE-S002",
      "priority": 2,
      "name": "Gambling Sites Instant Block",
      "description": "Zero tolerance for gambling - immediate permanent block",
      "enabled": true,
      "conditions": {
        "ai_score_min": 20,
        "threat_categories": ["gambling"]
      },
      "action": {
        "type": "block",
        "duration_seconds": 2592000,
        "alert_channels": ["email", "dashboard"],
        "note": "30-day block for gambling detection"
      },
      "metadata": {
        "created_by": "principal",
        "created_at": "2026-01-22T07:00:00Z",
        "tags": ["gambling", "permanent_block", "child_protection"]
      }
    },
    {
      "rule_id": "RULE-S003",
      "priority": 3,
      "name": "Social Media Block During School Hours",
      "description": "Block all social media during school hours (07:00-16:00)",
      "enabled": true,
      "conditions": {
        "ai_score_min": 15,
        "threat_categories": ["social_media"],
        "source_segments": ["student_labs", "student_wifi"],
        "time_windows": [
          {
            "days": ["monday", "tuesday", "wednesday", "thursday", "friday"],
            "start_time": "07:00",
            "end_time": "16:00"
          }
        ]
      },
      "action": {
        "type": "block",
        "duration_seconds": 3600,
        "alert_channels": ["dashboard"],
        "note": "Blocked during school hours to maintain focus"
      },
      "metadata": {
        "created_by": "principal",
        "created_at": "2026-01-22T07:00:00Z",
        "tags": ["social_media", "school_hours", "distraction_prevention"]
      }
    },
    {
      "rule_id": "RULE-S004",
      "priority": 4,
      "name": "Teacher Network Alert Then Block",
      "description": "Alert on first detection for teachers, block on repeat",
      "enabled": true,
      "conditions": {
        "ai_score_min": 50,
        "ai_score_max": 74,
        "source_segments": ["teacher_network"],
        "threat_categories": ["gambling"]
      },
      "action": {
        "type": "alert",
        "alert_channels": ["email", "dashboard"],
        "escalate_after": {
          "violations": 1,
          "time_window_minutes": 60,
          "escalate_to_action": "block"
        },
        "note": "Teachers get one warning before block"
      },
      "metadata": {
        "created_by": "principal",
        "created_at": "2026-01-22T07:00:00Z",
        "tags": ["teachers", "graduated_response"]
      }
    },
    {
      "rule_id": "RULE-S005",
      "priority": 5,
      "name": "Teacher High-Score Immediate Block",
      "description": "High confidence threats blocked immediately even for teachers",
      "enabled": true,
      "conditions": {
        "ai_score_min": 75,
        "source_segments": ["teacher_network"]
      },
      "action": {
        "type": "block",
        "duration_seconds": 86400,
        "alert_channels": ["email", "dashboard"]
      },
      "metadata": {
        "created_by": "principal",
        "created_at": "2026-01-22T07:00:00Z",
        "tags": ["teachers", "high_confidence"]
      }
    },
    {
      "rule_id": "RULE-S006",
      "priority": 6,
      "name": "Admin Network Monitoring",
      "description": "Monitor admin network but more lenient thresholds",
      "enabled": true,
      "conditions": {
        "ai_score_min": 70,
        "ai_score_max": 84,
        "source_segments": ["admin_network"]
      },
      "action": {
        "type": "alert",
        "alert_channels": ["email", "dashboard"],
        "escalate_after": {
          "violations": 2,
          "time_window_minutes": 120,
          "escalate_to_action": "block"
        }
      },
      "metadata": {
        "created_by": "principal",
        "created_at": "2026-01-22T07:00:00Z",
        "tags": ["admin", "monitoring"]
      }
    },
    {
      "rule_id": "RULE-S007",
      "priority": 7,
      "name": "Admin Network Critical Threats",
      "description": "Block critical threats on admin network immediately",
      "enabled": true,
      "conditions": {
        "ai_score_min": 85,
        "source_segments": ["admin_network"]
      },
      "action": {
        "type": "block",
        "duration_seconds": 86400,
        "alert_channels": ["email", "syslog", "dashboard"]
      },
      "metadata": {
        "created_by": "principal",
        "created_at": "2026-01-22T07:00:00Z",
        "tags": ["admin", "critical"]
      }
    },
    {
      "rule_id": "RULE-S008",
      "priority": 8,
      "name": "After Hours Stricter Enforcement",
      "description": "Even lower thresholds after school hours",
      "enabled": true,
      "conditions": {
        "ai_score_min": 20,
        "time_windows": [
          {
            "days": ["monday", "tuesday", "wednesday", "thursday", "friday"],
            "start_time": "16:01",
            "end_time": "06:59"
          },
          {
            "days": ["saturday", "sunday"],
            "start_time": "00:00",
            "end_time": "23:59"
          }
        ]
      },
      "action": {
        "type": "block",
        "duration_seconds": 86400,
        "alert_channels": ["dashboard"]
      },
      "metadata": {
        "created_by": "principal",
        "created_at": "2026-01-22T07:00:00Z",
        "tags": ["after_hours", "weekend", "strict"]
      }
    },
    {
      "rule_id": "RULE-S009",
      "priority": 9,
      "name": "Suspicious Burst Activity",
      "description": "Block rapid connection attempts that could be malware or abuse",
      "enabled": true,
      "conditions": {
        "ai_score_min": 30,
        "threat_categories": ["api_abuse"]
      },
      "action": {
        "type": "block",
        "duration_seconds": 3600,
        "alert_channels": ["email", "dashboard"]
      },
      "metadata": {
        "created_by": "principal",
        "created_at": "2026-01-22T07:00:00Z",
        "tags": ["burst", "abuse_prevention"]
      }
    }
  ],
  
  "audit_config": {
    "retention_days": 2555,
    "log_level": "info",
    "log_all_decisions": true,
    "export_format": ["json", "csv", "syslog"],
    "compliance_reporting": {
      "enabled": true,
      "report_frequency": "weekly",
      "recipients": [
        "principal@school.local",
        "it-admin@school.local",
        "safety-officer@school.local"
      ]
    }
  },
  
  "collectors": {
    "dnsmasq_log_path": "/var/log/dnsmasq.log",
    "zeek_ssl_log_path": "/var/log/zeek/ssl.log",
    "use_zeek_sni": true,
    "netflow_enabled": true
  },
  
  "enforcement": {
    "ipset_name_v4": "minifw_school_block_v4",
    "ipset_name_v6": "minifw_school_block_v6",
    "ip_timeout_seconds": 604800,
    "nft_table": "inet",
    "nft_chain": "forward"
  }
}