# V-Sentinel Demo Stack — local development only, do NOT use in production

PRODUCT_MODE=ritapi_v_sentinel

# Secrets (demo values — regenerate for any real deployment)
DJANGO_SECRET_KEY=demo-django-secret-key-change-before-any-real-use
MINIFW_SECRET_KEY=demo-minifw-secret-key-change-before-any-real-use
MINIFW_ADMIN_PASSWORD=admin
DB_PASSWORD=demo_db_pass

# Django
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
APP_VERSION=0.1.0-demo

# Database (points to the postgres service)
DB_NAME=ritapi_v_sentinel
DB_USER=ritapi
DB_HOST=postgres
DB_PORT=5432

# Redis (points to the redis service)
REDIS_URL=redis://redis:6379/0

# MiniFW — demo/observe-only mode
DEGRADED_MODE=1
MINIFW_DNS_SOURCE=none
MINIFW_ENFORCE=0
GAMBLING_ONLY=1
MLP_ENABLED=1
ALLOWED_DETECTION_TYPES=gambling

# MiniFW paths (resolved inside containers)
MINIFW_LOG=/minifw/logs/events.jsonl
MINIFW_FLOW_RECORDS=/minifw/logs/flow_records.jsonl
MINIFW_POLICY=/minifw_app/config/policy.json
MINIFW_FEEDS=/minifw_app/config/feeds
MINIFW_YARA_RULES=/minifw_app/yara_rules
MINIFW_MLP_MODEL=/minifw_app/models/mlp_engine.pkl

# Policy metadata
MODEL_NAME=v_sentinel_mlp
MODEL_VERSION=mlp_v2
POLICY_ID=V-SENTINEL-GOV-01
POLICY_VERSION=1.0
